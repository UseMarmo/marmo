{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Marmo",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$APPLOCALDATA/marmo/*" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$APPLOCALDATA/marmo/*" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$APPLOCALDATA/marmo" }, { "path": "$APPLOCALDATA/marmo/*" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$APPLOCALDATA/marmo" }]
    }
  ]
}
