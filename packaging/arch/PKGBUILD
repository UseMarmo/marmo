pkgname=marmo
pkgver=0.3.9
pkgrel=1
pkgdesc="Private 2-of-3 threshold wallet on Base"
arch=('x86_64')
url="https://github.com/UseMarmo/marmo"
license=('MIT')
depends=('webkit2gtk-4.1' 'gtk3' 'libappindicator-gtk3')
makedepends=('rust' 'cargo' 'bun-bin')
source=("$pkgname-$pkgver.tar.gz::https://github.com/UseMarmo/marmo/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "marmo-$pkgver/desktop"
    bun install --frozen-lockfile
    cargo fetch --target x86_64-unknown-linux-gnu
}

build() {
    cd "marmo-$pkgver/desktop"
    CARGO_NET_OFFLINE=true bun run tauri build --no-bundle
}

package() {
    cd "marmo-$pkgver/desktop"
    install -Dm755 "src-tauri/target/release/marmo-desktop" "$pkgdir/usr/bin/marmo"
    install -Dm644 "src-tauri/icons/128x128.png" "$pkgdir/usr/share/pixmaps/marmo.png"
    install -Dm644 "$startdir/marmo.desktop" "$pkgdir/usr/share/applications/marmo.desktop"
}
